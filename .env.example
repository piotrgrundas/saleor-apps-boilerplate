# Saleor
SALEOR_URL=https://<YOUR INSTANCE>.eu.saleor.cloud

# Logging
LOG_LEVEL=debug

# AWS Secrets Manager
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://host.docker.internal:4566

APP_CONFIG_STORE_PATH=saleor-app-config

# Development: Saleor Dashboard token for standalone mode
SALEOR_UI_APP_TOKEN=

# Localstack (for local development)

# Optional: URL prefix for the app
BASE_PATH=

# Server port (default: 3000)
PORT=3000
